{
  "name": "simple-yt-tweaks",
  "version": "0.3.0",
  "description": "Unofficial player usability tweaks for YouTube.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite build --watch",
    "icons": "node scripts/generate-icons.mjs",
    "assets:marketing": "node scripts/generate-marketing-assets.mjs",
    "version:sync": "node scripts/sync-version.mjs",
    "version:set": "node scripts/sync-version.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prebuild": "npm run version:sync",
    "build": "vite build",
    "validate": "node scripts/validate-extension.mjs",
    "validate:packaged": "node scripts/validate-extension.mjs --packaged",
    "package": "npm run build && npm run validate && node scripts/package-extension.mjs && npm run validate:packaged",
    "test:e2e": "npm run build && playwright test --project=fixtures",
    "test:e2e:live": "npm run build && SIMPLE_YT_TWEAKS_LIVE=1 playwright test --project=live",
    "validate:all": "npm run typecheck && npm run lint && git diff --check && npm run package && playwright test --project=fixtures"
  },
  "keywords": [
    "chrome-extension",
    "brave-extension",
    "manifest-v3",
    "youtube"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.33",
    "@types/node": "^25.0.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.7"
  }
}
